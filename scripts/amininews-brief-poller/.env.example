SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
OPENCLAW_BRIDGE_TOKEN=your_bridge_token
AMININEWS_USER_ID=your_user_id
BRIEF_OUTPUT_DIR=/home/openclaw/amininews-briefs

NOTEBOOKLM_COMMAND=/home/openclaw/.openclaw/skills/notebooklm/scripts/ingest_daily_brief.py {markdown_path}
NOTEBOOKLM_PROFILE=amininews
NOTEBOOKLM_NOTEBOOK_TITLE=AminiNews Daily Briefs
NOTEBOOKLM_NOTEBOOK_ALIAS=amininews-daily-briefs
NOTEBOOKLM_SOURCE_TITLE_PREFIX=AminiNews Daily Brief
NOTEBOOKLM_REQUIRE_AUTH=true
NOTEBOOKLM_AUTH_COMMAND=/home/openclaw/.openclaw/skills/notebooklm/scripts/ingest_daily_brief.py --auth-only

NOTEBOOKLM_CREATE_AUDIO=true
NOTEBOOKLM_AUDIO_FORMAT=brief
NOTEBOOKLM_AUDIO_LENGTH=default
NOTEBOOKLM_AUDIO_LANGUAGE=en
NOTEBOOKLM_AUDIO_TIMEOUT_SECONDS=900
NOTEBOOKLM_AUDIO_POLL_SECONDS=10
NOTEBOOKLM_AUDIO_FILE_PREFIX=podcast
NOTEBOOKLM_CLEANUP_OLD_CONTENT=true

NOTEBOOKLM_SEND_AUDIO_TO_TELEGRAM=true
NOTEBOOKLM_TELEGRAM_CHAT_ID=-100xxxxxxxxxx
NOTEBOOKLM_TELEGRAM_THREAD_ID=13
NOTEBOOKLM_PYTHON=/home/openclaw/.venv/bin/python
NOTEBOOKLM_OPENCLAW_BIN=/home/openclaw/.npm-global/bin/openclaw
NOTEBOOKLM_TELEGRAM_UPLOAD_DIR=/tmp/openclaw/uploads

# Optional overrides
# BRIEF_STATE_FILE=/home/openclaw/amininews-briefs/.brief-poller-state.json
# BRIEF_REQUEST_TIMEOUT_SECONDS=30
